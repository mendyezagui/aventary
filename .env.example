# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only

# Resend (transactional email)
RESEND_API_KEY=re_...
CONTACT_TO_EMAIL=mendy@aventary.com
CONTACT_FROM_EMAIL=noreply@aventary.com

# Admin allowlist (comma-separated lowercase emails that can access /admin)
ADMIN_EMAILS=mendy@aventary.com

# Meeting traffic-light (/status)
# Google Calendar → Settings → your calendar → "Secret address in iCal format".
# Leave unset to run the page on built-in demo events.
MEETING_ICAL_URL=https://calendar.google.com/calendar/ical/.../basic.ics
# Minutes before a meeting that the light turns yellow (default 5).
MEETING_WARN_MINUTES=5
# Optional shared secret. When set, /api/status requires ?token=... (or a
# Bearer header) except for same-origin requests. Put the same value in the
# device firmware so only your traffic light can read your meeting titles.
MEETING_STATUS_TOKEN=
