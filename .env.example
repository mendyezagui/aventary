# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only

# Resend (transactional email)
RESEND_API_KEY=re_...
CONTACT_TO_EMAIL=mendy@aventary.com
CONTACT_FROM_EMAIL=noreply@aventary.com

# Admin allowlist (comma-separated lowercase emails that can access /admin)
ADMIN_EMAILS=mendy@aventary.com

# ── Automation Loops ──────────────────────────────────────────────────────────
# These are set as SUPABASE EDGE FUNCTION secrets (not in the Next app), via
# `supabase secrets set ...` or the dashboard, for the `loops-dispatch` function:
#   ANTHROPIC_API_KEY=sk-ant-...     # drafting model
#   LOOPS_DISPATCH_SECRET=...        # shared secret; must match the pg_cron caller
# Approval emails reuse RESEND_API_KEY + CONTACT_FROM_EMAIL above.
