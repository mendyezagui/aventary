# Datadog telemetry for the Vantaca Slack bot — add these to the bot's env
# (e.g. the systemd unit / .env on the VPS where vantaca-slack runs).

# Required: an org-level Datadog API key (Organization Settings → API Keys).
DATADOG_API_KEY=

# US1 is the default; leave as-is unless your org is on another site.
DD_SITE=datadoghq.com

# Identity / tagging.
DD_SERVICE=vantaca-slack-bot
DD_ENV=prod
DD_HOSTNAME=vantaca-vps
# Optional extra tags, comma-separated, e.g. "client:scott-management,region:nyc"
DD_EXTRA_TAGS=

# Ops switches.
# DD_TELEMETRY_DISABLED=1   # hard kill-switch (also implied if no API key)
# DD_DEBUG=1                # log Datadog HTTP failures to stderr
